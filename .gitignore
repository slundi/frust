# ---> Rust
# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Cargo.lock: commit it for executables, ignore it for libraries.
# This template defaults to an executable (src/main.rs is present).
# If you convert this to a pure library, add `Cargo.lock` back to this file.
# More information: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# ---> VisualStudioCode
# Track shared settings; ignore everything else (per-user launch configs etc.)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix

# Coverage
lcov.info

# Nix
.direnv/
result
result-*
.envrc

# Local dev artifacts
.redb
frust.sqlite3
